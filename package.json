{
  "name": "nuxt-i18n-mcp",
  "version": "0.1.0-alpha.1",
  "description": "MCP server for managing i18n translation files in Nuxt projects",
  "type": "module",
  "bin": {
    "nuxt-i18n-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "schema.json"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:perf": "vitest run tests/perf/",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "glob": "^11.0.0",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "@nuxt/kit": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": false
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/kit": "^3.17.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
